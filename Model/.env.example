# Application
APP_ENV=development
LOG_LEVEL=INFO
API_SECRET_KEY=replace-me

# Scraping defaults
SCRAPE_QUERY=Data Engineer
SCRAPE_LOCATION=New York USA
SCRAPE_PAGES=1
SCRAPE_QUERIES=Data Engineer,Data Scientist,Data Analyst,Business Analyst,Machine Learning Engineer
SCRAPE_LOCATIONS=New York USA,San Francisco USA,Toronto Canada,London UK,Berlin Germany,Paris France,Sao Paulo Brazil,Mexico City Mexico,Dubai UAE,Singapore,Bangalore India,Tokyo Japan,Sydney Australia,Cape Town South Africa,Remote
MAX_RECORDS_PER_SOURCE=2500
SCRAPE_DELAY_SECONDS=1.8
REQUEST_TIMEOUT_SECONDS=35
INDEED_PAGES=8
INDEED_SITES=www.indeed.com,uk.indeed.com,ca.indeed.com,au.indeed.com,in.indeed.com,sg.indeed.com,de.indeed.com,fr.indeed.com,nl.indeed.com,br.indeed.com,mx.indeed.com,ae.indeed.com
INDEED_DELAY_SECONDS=2.0
LINKEDIN_PAGES=10
FRANCE_TRAVAIL_PAGES=8
THE_MUSE_PAGES=12
REMOTIVE_INCLUDE_ALL=true
REMOTIVE_CATEGORIES=data,software-dev,product
REMOTIVE_DELAY_SECONDS=1.5
GLASSDOOR_PAGES=8
GLASSDOOR_SITES=www.glassdoor.com,www.glassdoor.co.uk,www.glassdoor.de,www.glassdoor.fr,www.glassdoor.ca,www.glassdoor.com.au
GLASSDOOR_DELAY_SECONDS=2.5

# Datastores
WAREHOUSE_URL=postgresql://user:password@localhost:5432/jobs
OBJECT_STORE_BUCKET=data-talent-raw
VECTOR_DB_URL=postgresql://user:password@localhost:5432/vectors

# Neon Cloud Database
NEON_HOST=your-neon-host
NEON_PORT=5432
NEON_DATABASE=neondb
NEON_USER=neondb_owner
NEON_PASSWORD=your-neon-password
NEON_SSLMODE=require

# Apache Airflow Secrets
AIRFLOW_FERNET_KEY=your-generate-fernet-key-here
